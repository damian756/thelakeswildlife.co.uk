// Prisma schema for LakesWildlife - analytics only

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model PageView {
  id        String   @id @default(uuid())
  path      String
  referrer  String?
  device    String?
  createdAt DateTime @default(now())

  @@index([path])
  @@index([createdAt])
}
